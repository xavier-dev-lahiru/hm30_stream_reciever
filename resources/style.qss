/* =============================================================================
 * style.qss — SIYI HM30 RTP Receiver
 *
 * All visual styling lives here. C++ code must NOT call setStyleSheet() at
 * runtime. Dynamic state (connected / disconnected) is driven entirely through
 * Qt dynamic properties (`active="true"` / `active="false"`) set via
 * QLabel::setProperty() + QStyle::unpolish/polish().
 * ============================================================================= */

/* ---------------------------------------------------------------------------
 *  Base palette
 * --------------------------------------------------------------------------- */
QMainWindow,
QWidget {
    background-color: #0d1117;
    color:            #c9d1d9;
    font-family:      'Inter', 'Ubuntu', 'Segoe UI', sans-serif;
    font-size:        14pt;
}

/* ---------------------------------------------------------------------------
 *  Group boxes
 * --------------------------------------------------------------------------- */
QGroupBox {
    background-color: #161b22;
    border:           1px solid #30363d;
    border-radius:    10px;
    margin-top:       22px;
    padding:          22px 16px 16px 16px;
    font-weight:      bold;
    font-size:        14pt;
    color:            #58a6ff;
}

QGroupBox::title {
    subcontrol-origin:   margin;
    subcontrol-position: top left;
    padding:             4px 14px;
    color:               #58a6ff;
    font-size:           14pt;
}

/* ---------------------------------------------------------------------------
 *  Labels — base
 * --------------------------------------------------------------------------- */
QLabel {
    font-size: 13pt;
    color:     #c9d1d9;
}

/* ---------------------------------------------------------------------------
 *  Status bar
 * --------------------------------------------------------------------------- */
QStatusBar {
    background-color: #161b22;
    border-top:       1px solid #30363d;
    color:            #c9d1d9;
    font-size:        12pt;
    padding:          6px;
    min-height:       28px;
}

/* ---------------------------------------------------------------------------
 *  Video LED indicator (dynamic-property driven)
 *
 *  C++ sets:   label->setProperty("active", true/false);
 *              style()->unpolish(label); style()->polish(label);
 * --------------------------------------------------------------------------- */
QLabel#videoLed {
    font-size: 24pt;
    color:     #8b949e; /* default / unset */
}

QLabel#videoLed[active="true"] {
    color: #3fb950; /* green — stream live */
}

QLabel#videoLed[active="false"] {
    color: #f85149; /* red — no signal */
}

/* ---------------------------------------------------------------------------
 *  Video status label (dynamic-property driven)
 * --------------------------------------------------------------------------- */
QLabel#videoStatusLabel {
    font-size:   14pt;
    font-weight: bold;
    color:       #8b949e;
}

QLabel#videoStatusLabel[active="true"] {
    color: #3fb950;
}

QLabel#videoStatusLabel[active="false"] {
    color: #f85149;
}

/* ---------------------------------------------------------------------------
 *  FPS readout
 * --------------------------------------------------------------------------- */
QLabel#fpsLabel {
    color:       #58a6ff;
    font-size:   14pt;
    font-weight: bold;
}

/* ---------------------------------------------------------------------------
 *  Info panel text labels
 * --------------------------------------------------------------------------- */
QLabel#connLabel,
QLabel#streamInfo {
    font-size:   13pt;
    line-height: 1.6;
}

QLabel#perfInfo {
    font-size:   13pt;
    color:       #3fb950;
    line-height: 1.6;
}
