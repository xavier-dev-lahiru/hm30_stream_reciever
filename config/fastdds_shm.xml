<?xml version="1.0" encoding="UTF-8" ?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
        <transport_descriptor>
            <transport_id>shm_transport</transport_id>
            <type>SHM</type>
            <!-- Set SHM segment size to 32MB to easily fit 500,000-point clouds (16MB) -->
            <segment_size>33554432</segment_size>
            <maxMessageSize>33554432</maxMessageSize>
        </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="shm_participant" is_default_profile="true">
        <rtps>
            <!-- Explicitly enable our configured SHM transport -->
            <userTransports>
                <transport_id>shm_transport</transport_id>
            </userTransports>
            <useBuiltinTransports>true</useBuiltinTransports>
        </rtps>
    </participant>
</profiles>
